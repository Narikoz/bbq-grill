# ── PHP API Service ──────────────────────────────────
DB_HOST=          # จาก Railway MySQL plugin → copy MYSQLHOST
DB_PORT=          # จาก Railway MySQL plugin → copy MYSQLPORT
DB_NAME=          # จาก Railway MySQL plugin → copy MYSQLDATABASE
DB_USER=          # จาก Railway MySQL plugin → copy MYSQLUSER
DB_PASSWORD=      # จาก Railway MySQL plugin → copy MYSQLPASSWORD
APP_ENV=production
TZ=Asia/Bangkok
ALLOWED_ORIGINS=  # ใส่ URL ของ Frontend service เช่น https://bbq-frontend.up.railway.app

# ── Frontend Service ─────────────────────────────────
RAILWAY_API_URL=  # ใส่ URL ของ API service เช่น https://bbq-api.up.railway.app
